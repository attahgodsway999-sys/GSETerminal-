<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="Theme.GSETerminal" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/gse_green</item>
        <item name="colorPrimaryVariant">@color/gse_green</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/gse_amber</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowBackground">@color/bg_main</item>
    </style>

    <!-- MainActivity — no action bar, full screen WebView -->
    <style name="Theme.GSETerminal.NoActionBar" parent="Theme.GSETerminal">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- SplashActivity — dark background matching the tape colour -->
    <style name="Theme.GSETerminal.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
